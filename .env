# ─────────────────────────────────────────────
# CONFIGURAÇÕES DO MIKROTIK
# ─────────────────────────────────────────────
MIKROTIK_HOST=192.168.244.129
MIKROTIK_PORT=22
MIKROTIK_USER=api
MIKROTIK_PASS=1234

# ─────────────────────────────────────────────
# CONFIGURAÇÕES DO SERVIDOR
# ─────────────────────────────────────────────
PORT=3000

# ─────────────────────────────────────────────
# MODO MOCK (true = simula SSH, false = real)
# Mude para false quando for testar no MikroTik real
# ─────────────────────────────────────────────
MOCK_MODE=true

# ─────────────────────────────────────────────
# AUTENTICAÇÃO JWT
# Gere uma chave forte antes de ir para produção:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ─────────────────────────────────────────────
JWT_SECRET=troque_essa_chave_por_uma_segura_em_producao
JWT_EXPIRES_IN=8h

# ─────────────────────────────────────────────
# USUÁRIO DO SISTEMA (acesso à interface web)
# ─────────────────────────────────────────────
APP_USER=admin
APP_PASS=admin123